{
  "name": "helmisatria.com",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "blog:new": "node scripts/new-blog-post.mjs",
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "generate-sitemap": "node scripts/generate-sitemap.mjs",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/generate-sitemap.mjs && vite build && tsc --noEmit",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.28",
    "motion": "^12.42.2",
    "posthog-js": "^1.402.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@mdx-js/rollup": "^3.1.1",
    "@tanstack/router-cli": "^1.167.19",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "gray-matter": "^4.0.3",
    "rehype-pretty-code": "^0.14.4",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "wrangler": "^4.111.0"
  },
  "engines": {
    "node": ">=26"
  }
}
